# ── Go backend ────────────────────────────────────────────────────────────────
API_PORT=8080
ENVIRONMENT=development
JWT_SECRET=change_me_for_production

# ── MongoDB (matches docker-compose defaults) ─────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=rootpassword
MONGO_URI=mongodb://soundsync_app:apppassword@localhost:27017/soundsync
MONGO_DB=soundsync

# ── PostgreSQL (matches docker-compose defaults) ──────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=soundsync
PG_USER=postgres
PG_PASSWORD=postgres

