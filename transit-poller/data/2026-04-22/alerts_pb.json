        "header_text": {
          "translation": [
            {
              "text": "Capitol Hill Station elevator 1 out of service due to scheduled maintenance. The elevator at the E Denny Way exit serving the street, South Mezzanine, and platform is out of service. See below for alternate route information.",
              "language": "en"
            }
          ]
        },
        "description_text": {
          "translation": [
            {
              "text": "To ride the 1 Line and 2 Line from the street:\r\n\n1. Go to Broadway Ave E and turn right toward E John St.\r\n2. Enter the station at the corner of E John St and Broadway Ave E.\r\n3. Take the street level elevator down to the North Mezzanine for elevator access to the platform.\r\n\nTo ride the 1 Line and 2 Line from the South Mezzanine:\r\n\n1. Take the pedestrian walkway toward the west exit.\r\n2. Take elevator up to the street.\r\n3. Turn left on Broadway Ave E.\r\n4. Enter the station at the corner of E John St and Broadway Ave E.\r\n5. Take the street level elevator down to the North Mezzanine for elevator access to the platform.\r\n\nTo exit the station from the platform:\r\n\n1. Go to the opposite end of the platform toward the E John St exit.\r\n2. Take the platform elevator to the North Mezzanine.\r\n3. Take the elevator at the North Mezzanine up to the street (E John St & Broadway Ave E).",
              "language": "en"
            }
          ]
        },
        "severity_level": "WARNING",
        "url": {
