    {
      "id": "17314",
      "alert": {
        "effect": "OTHER_EFFECT",
        "effect_detail": {
          "translation": [
            {
              "text": "ANNOUNCEMENT",
              "language": "en"
            }
          ]
        },
        "cause": "MAINTENANCE",
        "cause_detail": {
          "translation": [
            {
              "text": "MAINTENANCE_ACTIVITY",
              "language": "en"
            }
          ]
        },
        "header_text": {
          "translation": [
            {
              "text": "On Saturday, April 25, from 4 a.m. through end of service on Sunday, April 26, Shuttle buses will be replace 1 Line trains between Rainier Beach Station and Sea/Tac Airport Station due to scheduled maintenance.",
              "language": "en"
            }
          ]
        },
        "description_text": {
          "translation": [
            {
              "text": "1 Line trains will run from Lynnwood City Center Station to Rainier Beach Station and from Sea/Tac Airport Station to Federal Way Station. Tukwila Int'l Blvd Station will remain closed during this disruption.\r\n\nTrains arrivals will vary:\r\n\n-Trains from Lynnwood City Center to Int'l District/Chinatown will arrive every 5 - 10 minutes until 1 p.m. on Saturday, April 25, and until noon on Sunday, April 26, due to the 2 Line signal upgrade.\r\n-Trains from Int'l District/Chinatown to Rainier Beach will arrive every 10 minutes.\r\n-Trains from Sea/Tac Airport to Federal Way will arrive every 10 minutes.\r\n\nEvening train times will run normal weekend service: Trains will arrive every 12 minutes from 9-11 p.m. and 16 minutes from 11 p.m. to last train.\r\n\nAt Rainier Beach Station, please board all trains on the platform to Lynnwood City Center Station.\r\n\nAt Sea/Tac Airport Station, please board all trains on the platform to Federal Way Downtown Station.\r\n\nPlease follow in-station signage and train signage to ensure that you board the correct train as platforms may change due to operational needs.\r\n\nFrom Rainier Beach to SeaTac/Airport station, 1 Line Shuttle buses will arrive about every 10 minutes. Please use 1 Line Shuttle stop signs to identify where to get on and off buses.\r\n\nBelow are Shuttle bus stops for affected stations:\r\n\nRainier Beach\r\n- To Lynnwood: M.L. King Jr Wy S and S Henderson St\r\n- To Federal Way: M.L. King Jr Wy S and S Henderson St\r\n\nTukwila\r\n- To Lynnwood: Tukwila International Boulevard Station, Bay 2\r\n- To Federal Way: Tukwila International Boulevard Station, Bay 3\r\n\nSea/Tacoma Airport\r\n- To Lynnwood: Tukwila International Blvd S and S 176 St\r\n- To Federal Way: Tukwila International Blvd S and S 176 St\r\n\nWe advise passengers to plan for additional travel time. Click the link below to get more information about alternative transportation options.\r\n\n\r\n",
              "language": "en"
            }
          ]
        },
        "severity_level": "WARNING",
        "url": {
          "translation": [
            {
              "text": "https://www.soundtransit.org/ride-with-us/changes-affect-my-ride/planned-service-disruptions",
              "language": "en"
            }
