        "cause": "CONSTRUCTION",
        "cause_detail": {
          "translation": [
            {
              "text": "SCHEDULED_MAINTENANCE",
              "language": "en"
            }
          ]
        },
        "header_text": {
          "translation": [
            {
              "text": "On Saturday, April 25, Sunday, April 26, and Saturday, May 2, from the start of service until noon, shuttle buses will replace 2 Line trains between Spring District and Overlake Village stations for scheduled maintenance.",
              "language": "en"
            }
          ]
        },
        "description_text": {
          "translation": [
            {
              "text": "Sound Transit is upgrading signaling equipment between Spring District and Overlake Village stations to improve system reliability.\r\n\n2 Line trains will arrive every 20 minutes between Lynnwood City Center and Spring District stations, and every 13 minutes between Overlake Village and Downtown Redmond stations.\r\n\nAt Wilburton and Spring District stations, please board all trains on the platform to Lynnwood. At Overlake Village Station, please board all trains on the platform to Downtown Redmond.\r\n\n2 Line shuttle buses will arrive about every 10 to 15 minutes.\r\n\nBelow are shuttle bus stops for affected stations:\r\n\nSpring District\r\n• To Lynnwood: 120th Ave NE & NE Spring Blvd\r\n• To Downtown Redmond: 120th Ave NE & NE Spring Blvd\r\n\nBelRed\r\n• To Lynnwood: 132nd Ave NE & NE Spring Blvd\r\n• To Downtown Redmond: 132nd Ave NE & NE Spring Blvd\r\n\nOverlake Village\r\n• To Lynnwood: 152nd Ave NE & Da Vinci Ave NE\r\n• To Downtown Redmond: 152nd Ave NE & NE Shen St",
              "language": "en"
            }
          ]
        },
        "severity_level": "SEVERE",
        "url": {
          "translation": [
            {
              "text": "https://www.soundtransit.org/ride-with-us/changes-affect-my-ride/planned-service-disruptions",
              "language": "en"
            }
          ]
        },
        "active_period": [
          {
            "start": 1777111200,
            "end": 1777748400
          }
        ],
        "informed_entity": [
          {
            "agency_id": "40",
            "route_type": 0,
            "route_id": "2LINE"
          }
        ]
      }
    },
