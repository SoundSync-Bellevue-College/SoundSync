{
    "info":  {
                 "_postman_id":  "9aa97334-7c08-4a2a-8aa8-8f40d72d6f17",
                 "name":  "SoundSync Auth Tests (Actual Data)",
                 "description":  "Auth-only Postman tests using actual seeded credentials from users.json and a stable signup user (temporary plaintext auth mode).",
                 "schema":  "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
             },
    "item":  [
                 {
                     "name":  "1. Login (Seeded User)",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"username\": \"{{seeded_username}}\",\n  \"password\": \"{{seeded_password}}\"\n}"
                                              },
                                     "url":  "{{base_url}}/api/v1/auth/login"
                                 },
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027status 200\u0027, function () { pm.response.to.have.status(200); });",
                                                                   "const body = pm.response.json();",
                                                                   "pm.test(\u0027token exists\u0027, function () { pm.expect(body.token).to.be.a(\u0027string\u0027); });",
                                                                   "pm.environment.set(\u0027jwt_token\u0027, body.token);"
                                                               ]
                                                  }
                                   }
                               ]
                 },
                 {
                     "name":  "2. Logout (Seeded User Token)",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Authorization",
                                                        "value":  "Bearer {{jwt_token}}"
                                                    }
                                                ],
                                     "url":  "{{base_url}}/api/v1/auth/logout"
                                 },
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027status 200\u0027, function () { pm.response.to.have.status(200); });",
                                                                   "pm.environment.unset(\u0027jwt_token\u0027);"
                                                               ]
                                                  }
                                   }
                               ]
                 },
                 {
                     "name":  "3. Signup (Actual Test User)",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"username\": \"{{signup_username}}\",\n  \"name\": \"{{signup_name}}\",\n  \"email\": \"{{signup_email}}\",\n  \"password\": \"{{signup_password}}\"\n}"
                                              },
                                     "url":  "{{base_url}}/api/v1/auth/signup"
                                 },
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "const code = pm.response.code;",
                                                                   "pm.test(\u0027status is 201 or already exists 400\u0027, function () { pm.expect([201, 400]).to.include(code); });"
                                                               ]
                                                  }
                                   }
                               ]
                 },
                 {
                     "name":  "4. Login (Signup User)",
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"username\": \"{{signup_username}}\",\n  \"password\": \"{{signup_password}}\"\n}"
                                              },
                                     "url":  "{{base_url}}/api/v1/auth/login"
                                 },
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027status 200\u0027, function () { pm.response.to.have.status(200); });"
                                                               ]
                                                  }
                                   }
                               ]
                 }
             ],
    "variable":  [
                     {
                         "key":  "base_url",
                         "value":  "http://localhost:8080"
                     },
                     {
                         "key":  "seeded_username",
                         "value":  "rider_dina"
                     },
                     {
                         "key":  "seeded_password",
                         "value":  "rider_dina_pass123"
                     },
                     {
                         "key":  "signup_username",
                         "value":  "postman_auth_user"
                     },
                     {
                         "key":  "signup_name",
                         "value":  "Postman Auth User"
                     },
                     {
                         "key":  "signup_email",
                         "value":  "postman_auth_user@soundsync.local"
                     },
                     {
                         "key":  "signup_password",
                         "value":  "postman_auth_pass123"
                     }
                 ]
}
