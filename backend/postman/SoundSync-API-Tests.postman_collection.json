                                                                   "const body = pm.response.json();",
                                                                   "pm.test(\u0027token returned\u0027, function () { pm.expect(body.token).to.be.a(\u0027string\u0027); });",
                                                                   "pm.environment.set(\u0027jwt_token\u0027, body.token);"
