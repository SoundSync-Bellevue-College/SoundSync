    "item":  [
                 {
                     "name":  "1. Health",
                     "request":  {
                                     "method":  "GET",
                                     "url":  "{{base_url}}/health"
                                 },
                     "event":  [
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027status 200\u0027, function () { pm.response.to.have.status(200); });",
                                                                   "const body = pm.response.json();",
                                                                   "pm.test(\u0027status ok\u0027, function () { pm.expect(body.status).to.eql(\u0027ok\u0027); });"
                                                               ]
                                                  }
                                   }
                               ]
                 },
                 {
                     "name":  "2. Signup",
                     "event":  [
                                   {
                                       "listen":  "prerequest",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "const unique = Date.now();",
                                                                   "pm.environment.set(\u0027test_username\u0027, `user_${unique}`);",
                                                                   "pm.environment.set(\u0027test_name\u0027, \u0027Postman Test User\u0027);",
                                                                   "pm.environment.set(\u0027test_email\u0027, `user_${unique}@soundsync.local`);",
                                                                   "pm.environment.set(\u0027test_password\u0027, \u0027secret123\u0027);"
                                                               ]
                                                  }
                                   },
                                   {
                                       "listen":  "test",
                                       "script":  {
                                                      "type":  "text/javascript",
                                                      "exec":  [
                                                                   "pm.test(\u0027status 201\u0027, function () { pm.response.to.have.status(201); });",
                                                                   "const body = pm.response.json();",
                                                                   "pm.test(\u0027user exists\u0027, function () {",
                                                                   "  pm.expect(body.user).to.be.an(\u0027object\u0027);",
                                                                   "  pm.expect(body.user.username).to.eql(pm.environment.get(\u0027test_username\u0027));",
                                                                   "  pm.expect(body.user.id).to.be.a(\u0027string\u0027);",
                                                                   "});"
                                                               ]
                                                  }
                                   }
                               ],
                     "request":  {
                                     "method":  "POST",
                                     "header":  [
                                                    {
                                                        "key":  "Content-Type",
                                                        "value":  "application/json"
                                                    }
                                                ],
                                     "body":  {
                                                  "mode":  "raw",
                                                  "raw":  "{\n  \"username\": \"{{test_username}}\",\n  \"name\": \"{{test_name}}\",\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}"
                                              },
                                     "url":  "{{base_url}}/api/v1/auth/signup"
                                 }
                 },
